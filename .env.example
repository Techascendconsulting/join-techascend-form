# Frontend (Vite) — use import.meta.env.VITE_* in browser code
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: success-screen WhatsApp link (overrides built-in default; no Supabase read)
# VITE_WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/your-invite

# Serverless API (/api/send-email) — set in Vercel Project → Settings → Environment Variables
# Local: copy to .env.local for `vercel dev` (not exposed to Vite bundle)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: for `npm run test:email` (or pass email as CLI arg after --)
# TEST_EMAIL_TO=you@example.com
